# Phase 27: CIC Integration Configuration

# Server
PORT=3000
NODE_ENV=development

# FamilySearch API
FAMILYSEARCH_API_URL=https://api.familysearch.org
FAMILYSEARCH_API_KEY=

# Warm Pool
WARM_POOL_TTL=3600000
WARM_POOL_MAX_SIZE=1000

# Drift Detection
DRIFT_CONFIDENCE_THRESHOLD=0.5
DRIFT_THRESHOLD=0.3

# SPA Hydration
SPA_LOW_CONFIDENCE_THRESHOLD=0.3

# Webhooks
TORQUE_QUERY_URL=http://localhost:9000
CHAT_AGENT_URL=http://localhost:8000
SLACK_WEBHOOK=
TEAMS_WEBHOOK=

# Webhook Timeout & Retries
WEBHOOK_TIMEOUT=5000
WEBHOOK_RETRIES=3

# Adapter Timeout & Retries
ADAPTER_TIMEOUT=10000
ADAPTER_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Metrics (for Prometheus)
METRICS_PORT=9090
METRICS_ENABLED=true

# Service Discovery
SERVICE_NAME=cic-ingestion
SERVICE_VERSION=1.0.0

# cic-ingestion environment variables

# Server port (default: 3000)
CIC_INGESTION_PORT=3000

# Google Vision API configuration
# Required for real image analysis; optional for development (falls back to mock)
VISION_API_KEY=<your-vision-api-key-or-leave-blank-for-mock>

# Path to Google service account JSON key file
# Required for Google Vision API calls; set this for real analysis
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Vision API provider (currently only 'google_vision' supported)
VISION_API_PROVIDER=google_vision

{
  "name": "cic-ingestion",
  "version": "0.1.0",
  "description": "CIC Autonomy & Memory Ingestion Engine with Caveman token compression",
  "type": "module",
  "main": "dist/cic-ingestion/src/autonomy/AutonomyAPIServer.js",
  "bin": {
    "cic": "dist/cic-ingestion/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cic-ingestion/src/autonomy/AutonomyAPIServer.js",
    "start:dev": "tsc 2>/dev/null || true; node dist/cic-ingestion/src/orchestrator/index.js",
    "dev": "tsc && node dist/cic-ingestion/src/autonomy/AutonomyAPIServer.js",
    "test": "node scripts/test-setup.js && npx jest",
    "test:watch": "node scripts/test-setup.js && npx jest --watch",
    "test:coverage": "node scripts/test-setup.js && npx jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "start:harvester-v2": "node dist/app/src/harvester/v2/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.16.0",
    "better-sqlite3": "^12.10.1",
    "commander": "^11.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "autonomy",
    "memory",
    "ingestion",
    "signal-detection",
    "roadmap-proposals",
    "caveman",
    "token-compression"
  ],
  "author": "CIC Team",
  "license": "MIT"
}

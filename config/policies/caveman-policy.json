{
  "version": "1.0.0",
  "phase": "1.1.1",
  "description": "Caveman compression governance policy",
  "effective_date": "2026-06-22",
  "policies": {
    "compression_modes": {
      "raw": {
        "enabled": true,
        "description": "v1 mode, no compression"
      },
      "semantic": {
        "enabled": false,
        "description": "v2 text-aware (spec-ready)"
      },
      "ast": {
        "enabled": false,
        "description": "v2 code-aware (spec-ready)"
      },
      "diff": {
        "enabled": false,
        "description": "v2 delta-based (spec-ready)"
      }
    },
    "budget_presets": {
      "low": {
        "mb_per_day": 5,
        "default": false
      },
      "medium": {
        "mb_per_day": 10,
        "default": true
      },
      "high": {
        "mb_per_day": 20,
        "default": false
      }
    },
    "enforcement": {
      "enabled": true,
      "block_on_budget_exceeded": true,
      "alert_at_percent": 80,
      "alert_path": "/app/data/caveman-alerts.log"
    },
    "stats": {
      "enabled": true,
      "track_compression_ratio": true,
      "track_governance_decisions": true,
      "v2_compatibility": true
    }
  }
}

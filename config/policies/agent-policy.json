{
  "version": "1.0.0",
  "phase": "1.1.1",
  "description": "Agent spawning and execution policy",
  "effective_date": "2026-06-22",
  "policies": {
    "agent_spawning": {
      "enabled": true,
      "approved_agent_types": [
        "memory-learner",
        "skill-discoverer",
        "plan-optimizer",
        "governance-counsel",
        "knowledge-graph-builder",
        "autonomy-monitor",
        "evolution-evaluator"
      ],
      "max_concurrent_agents": 10,
      "max_per_type": 2,
      "spawn_timeout_ms": 5000
    },
    "agent_lifecycle": {
      "heartbeat_interval_ms": 30000,
      "heartbeat_timeout_ms": 60000,
      "max_agent_lifetime_hours": 24,
      "enforce_shutdown": true
    },
    "agent_communication": {
      "enabled": true,
      "message_bus": "distributed",
      "max_message_size_bytes": 1000000,
      "message_timeout_ms": 10000,
      "log_all_messages": true
    },
    "resource_limits": {
      "memory_per_agent_mb": 500,
      "cpu_shares_per_agent": 1024,
      "disk_quota_mb": 1000
    },
    "audit": {
      "enabled": true,
      "log_path": "/app/data/agent-audit.log",
      "log_level": "info"
    }
  }
}
